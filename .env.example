# ═══════════════════════════════════════════════════════════════════════════════
#  Thiny — environment configuration
#  Copy to .env and fill in your values.
#  See thiny.config.example.json for a config-file alternative.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Model selection ────────────────────────────────────────────────────────────
# Pick ONE of the setups below. THINY_MODEL overrides thiny.config.json.

# 1. OpenAI
THINY_MODEL=openai:gpt-4o-mini
THINY_OPENAI_API_KEY=sk-...

# 2. Anthropic
# THINY_MODEL=anthropic:claude-haiku-4-5-20251001
# THINY_ANTHROPIC_API_KEY=sk-ant-...

# 3. Ollama  (local · free · run `ollama pull llama3` first)
# THINY_MODEL=openai-compat:llama3
# THINY_OPENAI_BASE_URL=http://localhost:11434/v1
# THINY_OPENAI_API_KEY=ollama

# 4. LM Studio  (local · free · start LM Studio server first)
# THINY_MODEL=openai-compat:local-model
# THINY_OPENAI_BASE_URL=http://localhost:1234/v1
# THINY_OPENAI_API_KEY=lm-studio

# 5. Groq  (fast · generous free tier)
# THINY_MODEL=openai-compat:llama-3.1-70b-versatile
# THINY_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# THINY_OPENAI_API_KEY=gsk_...

# 6. Together AI
# THINY_MODEL=openai-compat:meta-llama/Llama-3-70b-chat-hf
# THINY_OPENAI_BASE_URL=https://api.together.xyz/v1
# THINY_OPENAI_API_KEY=...

# 7. OpenRouter  (100+ models with one key)
# THINY_MODEL=openai-compat:anthropic/claude-3.5-haiku
# THINY_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# THINY_OPENAI_API_KEY=sk-or-...

# 8. Azure OpenAI
# THINY_MODEL=openai-compat:my-deployment-name
# THINY_OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<name>
# THINY_OPENAI_API_KEY=...

# 9. Anthropic via proxy
# THINY_MODEL=anthropic:claude-3-5-haiku-20241022
# THINY_ANTHROPIC_BASE_URL=https://my-proxy.example.com
# THINY_ANTHROPIC_API_KEY=proxy-key

# ── Optional features ──────────────────────────────────────────────────────────
BRAVE_API_KEY=              # enables web_search tool
LOG_LEVEL=info              # debug | info | warn | error
AUDIT_LOG=                  # write structured JSON audit trail to this file (e.g. audit.log)

# ── Web3 / EVM testnet ─────────────────────────────────────────────────────────
# EVM_RPC_URL=https://sepolia.infura.io/v3/<key>
# AGENT_PRIVATE_KEY=0x...   # testnet-only throwaway key
# EVM_ALLOWLIST=0xAddr1,0xAddr2
