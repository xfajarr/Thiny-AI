{
  "name": "@thiny/skills",
  "version": "0.1.0",
  "description": "Thiny AI — lightweight skill metadata registry for agent capability discovery",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiny-ai/thiny.git",
    "directory": "packages/skills"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --config ../../tsup.config.ts"
  },
  "dependencies": {
    "@thiny/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.0"
  },
  "author": "Thiny AI",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "homepage": "https://github.com/thiny-ai/thiny/tree/main/packages/skills#readme",
  "bugs": {
    "url": "https://github.com/thiny-ai/thiny/issues"
  },
  "keywords": [
    "ai-agent",
    "llm",
    "thiny",
    "skills",
    "registry",
    "metadata",
    "discovery"
  ]
}
