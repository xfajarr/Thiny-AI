{
  "name": "@thiny/agent",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "@thiny/core": "workspace:*",
    "@thiny/eval": "workspace:*",
    "@thiny/logger-pino": "workspace:*",
    "@thiny/mcp": "workspace:*",
    "@thiny/memory-sqlite": "workspace:*",
    "@thiny/model-aisdk": "workspace:*",
    "@thiny/plugin-evm": "workspace:*",
    "@thiny/plugin-solana": "workspace:*",
    "@thiny/plugin-web-search": "workspace:*",
    "@thiny/runtime": "workspace:*",
    "@thiny/signer-viem": "workspace:*"
  },
  "devDependencies": {
    "@thiny/core": "workspace:*",
    "@thiny/eval": "workspace:*",
    "@thiny/logger-pino": "workspace:*",
    "@thiny/mcp": "workspace:*",
    "@thiny/memory-sqlite": "workspace:*",
    "@thiny/model-aisdk": "workspace:*",
    "@thiny/plugin-evm": "workspace:*",
    "@thiny/plugin-solana": "workspace:*",
    "@thiny/plugin-web-search": "workspace:*",
    "@thiny/runtime": "workspace:*",
    "@thiny/signer-viem": "workspace:*"
  },
  "scripts": {
    "build": "tsup src/index.ts --config ../../tsup.config.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
